import os
from pathlib import Path

# Root of Django project: src/backend_django
BASE_DIR = Path(__file__).resolve().parent.parent.parent.parent
PROJECT_NAME = os.environ.get("PROJECT_NAME", "project_landing")

# ═══════════════════════════════════════════
# Static & Media
# ═══════════════════════════════════════════

STATIC_URL = "/static/"
STATICFILES_DIRS = [BASE_DIR / "static"]

# В Docker мы собираем статику в подпапку с именем проекта
if os.environ.get("IS_DOCKER", "False").lower() in ("true", "1", "t"):
    STATIC_ROOT = Path("/app/staticfiles") / PROJECT_NAME
    MEDIA_ROOT = Path("/app/media") / PROJECT_NAME
else:
    STATIC_ROOT = BASE_DIR / "staticfiles"
    MEDIA_ROOT = BASE_DIR / "media"

# We ignore source CSS files that are compiled into app.css
STATICFILES_IGNORE_PATTERNS = [
    "css/base/*",
    "css/adaptive/*",
    "css/components/*",
    "css/cabinet/*",
    "css/pages/*",
    "css/base.css",
    "css/cabinet.css",
]

MEDIA_URL = "/media/"

DEFAULT_AUTO_FIELD = "django.db.models.BigAutoField"
